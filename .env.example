# ── Copy this file to .env and fill in your keys ──────────────────────────────

# Pick whichever LLM your team has access to.
# The router + experts will use the first available key in this order:
#   1. Anthropic  2. OpenAI  3. Google Gemini

ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
GEMINI_API_KEY=your_gemini_key_here

# Which model to use for the MoE router classification call
# Anthropic:  claude-haiku-4-5-20251001   (fast + cheap)
# OpenAI:     gpt-4o-mini
# Gemini:     gemini-1.5-flash
ROUTER_MODEL_PROVIDER=anthropic
ROUTER_MODEL_NAME=claude-haiku-4-5-20251001

# Team 2 existing webhook (used as Expert 2 fallback if direct call unavailable)
TEAM2_WEBHOOK_URL=https://jiakainiu.app.n8n.cloud/webhook/30146b5a-8c33-4003-9c6d-44114badce13

# Server settings
HOST=0.0.0.0
PORT=8000
